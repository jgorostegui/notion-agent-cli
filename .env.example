# Notion integration token
# Create at: https://www.notion.so/profile/integrations
# Then share your pages/databases with the integration in Notion
NOTION_TOKEN=ntn_your_token_here

# Benchmark fixtures (only needed for running benchmarks)
# BENCH_PAGE=           # Source page ID (content-rich, ~5000 words)
# BENCH_PARENT=         # Parent page ID (empty, for created pages)
# BENCH_DB=             # Database ID (with Status, Priority, Category props)
# BENCH_ENTRY=          # Single database entry ID (for S4)
# BENCH_ENTRIES=        # Comma-separated entry IDs (for S7, 3 entries)
# BENCH_MERGE_SOURCES=  # Comma-separated page IDs (for S6, 3 pages)
# BENCH_SECTION=        # Heading name in BENCH_PAGE (for S5, e.g. "Goals")
