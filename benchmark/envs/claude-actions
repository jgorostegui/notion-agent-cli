#!/usr/bin/env bash
# CLI benchmark wrapper: isolated HOME with notion-agent-cli plugin, empty workdir.
ORIG_HOME="$HOME"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_DIR="$(cd "$SCRIPT_DIR/../.." && pwd)"
export HOME="$ORIG_HOME/.claude-bench-actions"
cd "$SCRIPT_DIR/workdir"
claude --plugin-dir "$PLUGIN_DIR" "$@"
